# Optional: set LLM_PROVIDER=openai to prefer OpenAI instead of the default gemini.
GEMINI_API_KEY=the actual key
GEMINI_MODEL=gemini-2.5-flash-lite
OPENAI_API_KEY=the actual key
OPENAI_MODEL=gpt-5.4-mini
AI_MODE=triage

# Optional: local admission-control knobs for proactive rate limiting.
# Example free-tier settings:
LLM_RATE_LIMIT_RPM=15
LLM_RATE_LIMIT_BURST=4
LLM_RATE_LIMIT_MAX_WAIT_SECONDS=2